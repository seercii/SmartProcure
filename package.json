{
  "name": "SmartProcure",
  "version": "1.0.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@sap/cds": "^9.8.5",
    "@sap/cds-dk": "^7",
    "dotenv": "^17.4.2",
    "express": "^4",
    "node-fetch": "^3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      }
    }
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
